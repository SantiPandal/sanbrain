# Sanbrain environment — copy to ~/.sanbrain.env and chmod 600.
# Sourced by scripts/lib.sh in every script. Cron does NOT read .zshrc,
# so secrets the pipeline needs must live here, not in shell rc files.

# Whisper transcription (harvest-recordings)
export OPENAI_API_KEY=""

# Optional overrides (defaults shown)
# export VAULT="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/VAULT"
# export VAULT_GIT_DIR="$HOME/.sanbrain-vault.git"
# export TELEGRAM_GROUP="-1003637114912"
# export TELEGRAM_SANBRAIN_THREAD="34"

# Downloads working-directory cleanup (process-downloads.py)
#   Idle files & already-saved files move to macOS Trash (recoverable ~30d).
#   One-way doors (fiscal/legal) are saved to raw/legal/ first; crypto keys
#   (.cer/.key/.p12) are never touched. Nothing is ever os.remove'd.
# export DOWNLOADS_IDLE_DAYS="14"     # days untouched before a two-way file ages out
# export DOWNLOADS_TRASH_MAX_MB="500" # files larger than this are flagged, not trashed
# Setup on the Mac mini (one-time):
#   - /usr/bin/trash must exist (Apple's trash(8), macOS 15+). Needs NO TCC grant
#     to write into ~/.Trash and records Finder "Put Back".
#   - Seed the provenance ledger ONCE from a Full-Disk-Access Terminal so the
#     launchd job recognizes already-saved files (it can't read the iCloud vault
#     itself under launchd):  scripts/process-downloads.py --reconcile
#   - First real run: try  scripts/process-downloads.py --dry-run --json  to see
#     exactly what it would trash/save before letting the nightly act.
#   - Recommended: if you enable Finder's "Remove items from Trash after 30 days",
#     30 days becomes a hard purge ceiling macOS enforces (independent of us).

# Sanbrain Cron Schedule
# Edit VAULT_PATH and HARNESS_CMD before installing.
# Install with: crontab crontab.example
#
# VAULT_PATH: your Obsidian vault location
# HARNESS_CMD: how you invoke your harness
#   OpenClaw:  curl -X POST http://localhost:PORT/message -d '{"content": "PROMPT"}'
#   Claude CLI: claude -p "PROMPT"
#   Custom:     your-harness "PROMPT"

VAULT_PATH="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/VAULT"
SANBRAIN_PATH="$HOME/sanbrain"

# ============================================================
# CAPTURE — get data into the vault
# ============================================================

# Extract insights from Claude sessions every 30 minutes
*/30 * * * * HARNESS_CMD "Read $SANBRAIN_PATH/skills/claude-extract/SKILL.md and run it. Vault path: $VAULT_PATH"

# ============================================================
# OUTPUT — compile and surface
# ============================================================

# Morning context file for Claude Code (6 AM)
0 6 * * * HARNESS_CMD "Read $SANBRAIN_PATH/skills/context-for-claude-code/SKILL.md and run it. Vault path: $VAULT_PATH"

# Nightly dream cycle (11 PM)
0 23 * * * HARNESS_CMD "Read $SANBRAIN_PATH/skills/daily-compile/SKILL.md and run it. Vault path: $VAULT_PATH"

# ============================================================
# MANUAL — triggered by user, not cron
# ============================================================
# meeting-ingest:  "Read skills/meeting-ingest/SKILL.md and run it."
# media-ingest:    "Read skills/media-ingest/SKILL.md and run it."
# book-mirror:     "Read skills/book-mirror/SKILL.md and run it."
# enrich:          "Read skills/enrich/SKILL.md and run it."
#
# entity-propagate: auto-fires after any skill writes a page
